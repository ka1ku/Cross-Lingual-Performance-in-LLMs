\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Final-layer RSA $r$ (Mistral left, Qwen2 right). EN--EU factual near zero/negative; EN--ES math highest.}}{7}{figure.caption.9}\protected@file@percent }
