\newlabel{sec:results_accuracy}{{4.1}{4}{Black-Box Accuracy}{subsection.4.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Black-box accuracy (\%) by language, category, and model. \textbf  {Bold} indicates best result per cell. Qwen2-7B is substantially more robust on Basque across all categories.}}{4}{table.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:accuracy}{{1}{4}{Black-box accuracy (\%) by language, category, and model. \textbf {Bold} indicates best result per cell. Qwen2-7B is substantially more robust on Basque across all categories}{table.caption.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Accuracy heatmaps for Mistral-7B (left) and Qwen2-7B (right). Rows are languages, columns are task categories. Qwen2-7B's advantage is most dramatic on Basque, particularly for math (65\% vs.\ 20\%) and factual (30\% vs.\ 0\%). Both models achieve 100\% English factual accuracy.}}{5}{figure.caption.2}\protected@file@percent }
\newlabel{fig:accuracy_heatmap}{{1}{5}{Accuracy heatmaps for Mistral-7B (left) and Qwen2-7B (right). Rows are languages, columns are task categories. Qwen2-7B's advantage is most dramatic on Basque, particularly for math (65\% vs.\ 20\%) and factual (30\% vs.\ 0\%). Both models achieve 100\% English factual accuracy}{figure.caption.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Logit Lens: Layer-by-Layer Prediction Trajectories}{5}{subsection.4.2}\protected@file@percent }
\newlabel{sec:results_logitlens}{{4.2}{5}{Logit Lens: Layer-by-Layer Prediction Trajectories}{subsection.4.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Logit lens summary for Mistral-7B-Instruct-v0.2: mean ground-truth rank (lower is better) and mean top-1 confidence at layers 1 and 32.}}{5}{table.caption.3}\protected@file@percent }
\newlabel{tab:logitlens}{{2}{5}{Logit lens summary for Mistral-7B-Instruct-v0.2: mean ground-truth rank (lower is better) and mean top-1 confidence at layers 1 and 32}{table.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Mean ground-truth token rank as a function of normalized layer depth, for all languages and categories, for Mistral-7B (top row) and Qwen2-7B (bottom row). Lower rank is better. The Basque factual curve remains elevated throughout all layers in Mistral, while Qwen2 shows improved convergence. Note Qwen2's higher absolute ranks reflect its larger vocabulary (152K tokens).}}{6}{figure.caption.4}\protected@file@percent }
\newlabel{fig:gt_rank}{{2}{6}{Mean ground-truth token rank as a function of normalized layer depth, for all languages and categories, for Mistral-7B (top row) and Qwen2-7B (bottom row). Lower rank is better. The Basque factual curve remains elevated throughout all layers in Mistral, while Qwen2 shows improved convergence. Note Qwen2's higher absolute ranks reflect its larger vocabulary (152K tokens)}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Mean top-1 token probability (confidence) as a function of layer, for both models. All languages converge to near-zero confidence in early layers (uniform distribution over vocabulary), then sharply increase in later layers. Basque reasoning maintains the lowest final-layer confidence for Mistral (53.9\%), consistent with its 5\% accuracy.}}{6}{figure.caption.5}\protected@file@percent }
\newlabel{fig:confidence}{{3}{6}{Mean top-1 token probability (confidence) as a function of layer, for both models. All languages converge to near-zero confidence in early layers (uniform distribution over vocabulary), then sharply increase in later layers. Basque reasoning maintains the lowest final-layer confidence for Mistral (53.9\%), consistent with its 5\% accuracy}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {paragraph}{Finding 1: Math is language-agnostic in early layers.}{7}{figure.caption.5}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 2: Basque factual representations fail to converge.}{7}{figure.caption.5}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 3: Reasoning confidence reveals ``undecided'' processing.}{7}{figure.caption.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}RSA: Cross-Lingual Representational Alignment}{7}{subsection.4.3}\protected@file@percent }
\newlabel{sec:results_rsa}{{4.3}{7}{RSA: Cross-Lingual Representational Alignment}{subsection.4.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces RSA Spearman $r$ between language-pair RDMs at selected layers, for Mistral-7B. Bold: highest correlation per row. Underline: negative (anti-correlated) values.}}{7}{table.caption.6}\protected@file@percent }
\newlabel{tab:rsa}{{3}{7}{RSA Spearman $r$ between language-pair RDMs at selected layers, for Mistral-7B. Bold: highest correlation per row. Underline: negative (anti-correlated) values}{table.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces RSA Spearman $r$ curves across all layers, for Mistral-7B (top) and Qwen2-7B (bottom), for each language pair and task category. The mid-layer peak for EN--ES reasoning is clearly visible in Mistral (top center). Qwen2 generally shows lower and noisier RSA values, despite its higher Basque accuracy.}}{8}{figure.caption.7}\protected@file@percent }
\newlabel{fig:rsa_curves}{{4}{8}{RSA Spearman $r$ curves across all layers, for Mistral-7B (top) and Qwen2-7B (bottom), for each language pair and task category. The mid-layer peak for EN--ES reasoning is clearly visible in Mistral (top center). Qwen2 generally shows lower and noisier RSA values, despite its higher Basque accuracy}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces RSA Spearman $r$ at the final layer for all language pairs and categories (Mistral left, Qwen2 right). The EN--EU factual cell is near zero or negative for both models, while EN--ES math maintains the highest alignment.}}{8}{figure.caption.8}\protected@file@percent }
\newlabel{fig:rsa_heatmap}{{5}{8}{RSA Spearman $r$ at the final layer for all language pairs and categories (Mistral left, Qwen2 right). The EN--EU factual cell is near zero or negative for both models, while EN--ES math maintains the highest alignment}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces EN--EU vs.\ EN--ES RSA gap by layer, for each task category (Mistral-7B). Shaded region marks the gap between the two curves. The gap is largest for factual and reasoning, where Basque representations diverge from English while Spanish remains aligned.}}{9}{figure.caption.9}\protected@file@percent }
\newlabel{fig:basque_gap}{{6}{9}{EN--EU vs.\ EN--ES RSA gap by layer, for each task category (Mistral-7B). Shaded region marks the gap between the two curves. The gap is largest for factual and reasoning, where Basque representations diverge from English while Spanish remains aligned}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {paragraph}{Finding 4: Math has the strongest and most durable cross-lingual alignment.}{9}{figure.caption.9}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 5: Basque-English factual alignment becomes structurally random.}{9}{figure.caption.9}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 6: Reasoning EN--ES peaks in mid-layers---evidence for implicit translation.}{9}{figure.caption.9}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 7: Early layers show language-agnostic structure even for Basque.}{9}{figure.caption.9}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Cross-Model Comparison}{10}{subsection.4.4}\protected@file@percent }
\newlabel{sec:results_cross_model}{{4.4}{10}{Cross-Model Comparison}{subsection.4.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces RSA Spearman $r$ at the final layer, compared between Mistral-7B and Qwen2-7B. Bold indicates the model with higher RSA per cell. Qwen2 achieves better Basque accuracy but shows \emph  {lower} EN--ES RSA, suggesting different internal multilingual representations.}}{10}{table.caption.10}\protected@file@percent }
\newlabel{tab:rsa_comparison}{{4}{10}{RSA Spearman $r$ at the final layer, compared between Mistral-7B and Qwen2-7B. Bold indicates the model with higher RSA per cell. Qwen2 achieves better Basque accuracy but shows \emph {lower} EN--ES RSA, suggesting different internal multilingual representations}{table.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Cross-model GT rank trajectories for each language and category. Mistral-7B (solid) and Qwen2-7B (dashed) are overlaid. Qwen2's higher absolute rank values reflect its larger vocabulary (152K vs.\ 32K), making direct rank comparison across models uninformative; the trajectory \emph  {shapes} are more comparable.}}{10}{figure.caption.11}\protected@file@percent }
\newlabel{fig:cross_model}{{7}{10}{Cross-model GT rank trajectories for each language and category. Mistral-7B (solid) and Qwen2-7B (dashed) are overlaid. Qwen2's higher absolute rank values reflect its larger vocabulary (152K vs.\ 32K), making direct rank comparison across models uninformative; the trajectory \emph {shapes} are more comparable}{figure.caption.11}{}}
